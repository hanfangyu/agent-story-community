{
  "version": "2.0",
  "envId": "flappy-prod-8gz5si41e56c3d8f",
  "$schema": "https://framework-1258016615.tcloudbaseapp.com/schema/latest.json",
  "functionRoot": "./functions",
  "functions": [],
  "region": "ap-guangzhou",
  "framework": {
    "name": "agent-story-community",
    "plugins": {
      "container": {
        "use": "@cloudbase/framework-plugin-container",
        "inputs": {
          "serviceName": "agent-story-community",
          "servicePath": "/",
          "localPath": "./",
          "uploadType": "image",
          "containerPort": 3000,
          "envVariables": {
            "DATABASE_URL": "${DATABASE_URL}",
            "POSTGRES_URL": "${POSTGRES_URL}",
            "SUPABASE_URL": "${SUPABASE_URL}",
            "SUPABASE_ANON_KEY": "${SUPABASE_ANON_KEY}"
          },
          "minNum": 0,
          "maxNum": 10,
          "cpu": 0.25,
          "mem": 0.5,
          "policyType": "cpu",
          "policyThreshold": 60,
          "customLogs": "stdout"
        }
      }
    }
  }
}
